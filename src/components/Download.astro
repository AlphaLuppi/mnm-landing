---
// Download section — macOS is available as Developer Preview (dev-only bundle,
// ad-hoc signed, requires a locally running backend). Windows + Linux are
// still placeholder "Coming soon".

const RELEASE_TAG = "desktop-v0.1.0-preview";
const MACOS_DMG = `https://github.com/AlphaLuppi/mnm/releases/download/${RELEASE_TAG}/MnM_0.1.0_aarch64.dmg`;

const platforms = [
  {
    name: "macOS",
    subtitle: "Apple Silicon",
    status: "Developer Preview",
    eta: "v0.1.0 available",
    available: true,
    href: MACOS_DMG,
  },
  {
    name: "Windows",
    subtitle: "x64 + ARM64",
    status: "Coming soon",
    eta: "Planned",
    available: false,
    href: null,
  },
  {
    name: "Linux",
    subtitle: "AppImage, deb, rpm",
    status: "Coming soon",
    eta: "Planned",
    available: false,
    href: null,
  },
];
---

<section id="download" class="relative px-6 lg:px-12 py-32 lg:py-48">
  <div class="mx-auto max-w-7xl">
    <!-- Section intro -->
    <div class="mb-20 max-w-3xl" data-fade>
      <div class="flex items-center gap-3 mb-8">
        <span class="h-px w-12 bg-[color:var(--color-line-strong)]"></span>
        <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-[color:var(--color-ink-mute)]">
          Download
        </span>
      </div>
      <h2 class="font-display text-4xl md:text-5xl lg:text-6xl leading-[1.05] tracking-tight">
        Native desktop,<br/>
        <span class="italic text-[color:var(--color-ink-soft)]">three platforms.</span>
      </h2>
      <p class="mt-8 text-lg text-[color:var(--color-ink-soft)] max-w-xl font-light">
        Built with Tauri 2. Same React UI as the web version, wrapped in a
        native shell — faster, lighter, and closer to the OS.
      </p>
    </div>

    <!-- Platform cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-[color:var(--color-line)]">
      {platforms.map((p, i) => (
        <div
          class="bg-[color:var(--color-paper)] p-10 lg:p-12 min-h-[20rem] flex flex-col group"
          data-fade
          style={`--fade-delay: ${i * 120}ms;`}
        >
          <div class="flex items-start justify-between mb-10">
            <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-ink-faint)]">
              {p.subtitle}
            </span>
            <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-[color:var(--color-ink-faint)]">
              {p.eta}
            </span>
          </div>

          <h3 class="font-display text-3xl md:text-4xl lg:text-5xl leading-none tracking-tight mb-8">
            {p.name}
          </h3>

          <div class="mt-auto">
            {p.available ? (
              <a
                href={p.href}
                class="group/btn inline-flex items-center gap-3 px-6 py-3 bg-[color:var(--color-ink)] text-[color:var(--color-paper)] text-xs font-mono uppercase tracking-[0.15em] hover:bg-[color:var(--color-ink-soft)] transition-colors"
              >
                {p.status}
                <span class="text-[10px] opacity-60 group-hover/btn:translate-y-0.5 transition-transform">↓</span>
              </a>
            ) : (
              <div class="inline-flex items-center gap-3 px-5 py-3 border border-[color:var(--color-line-strong)] text-[color:var(--color-ink-mute)] text-xs font-mono uppercase tracking-[0.15em] cursor-not-allowed">
                {p.status}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Setup guide -->
    <div id="setup" class="scroll-mt-28 mt-12" data-fade>
      <div id="mnm-setup-guide" class="p-8 lg:p-10 border border-[color:var(--color-line-strong)] bg-[color:var(--color-paper-aged)]">
        <div class="flex items-start gap-6">
          <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-accent)] pt-1 flex-shrink-0">
            ⚠ &nbsp;Important
          </span>
          <div class="flex-1">
            <h3 class="font-display text-2xl md:text-3xl leading-tight mb-4">
              MnM Desktop needs a backend.
            </h3>
            <p class="text-sm md:text-base text-[color:var(--color-ink-soft)] font-light leading-relaxed mb-8 max-w-3xl">
              The desktop app is a <strong class="text-[color:var(--color-ink)] font-medium">thin client</strong> that connects to an MnM backend.
              The backend is not shipped with the app — it runs separately, either on your company's server or on your own machine.
              It is distributed <strong class="text-[color:var(--color-ink)] font-medium">on request</strong>, not via public download.
            </p>

            <!-- Two deployment paths -->
            <div class="grid md:grid-cols-2 gap-px bg-[color:var(--color-line)] border border-[color:var(--color-line)] mb-8">
              <div class="bg-[color:var(--color-paper)] p-6">
                <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-ink-faint)] mb-3">
                  Option A &nbsp;·&nbsp; Company server
                </p>
                <h4 class="font-display text-xl leading-tight mb-3">Shared deployment.</h4>
                <p class="text-sm text-[color:var(--color-ink-soft)] font-light leading-relaxed">
                  Your IT team installs MnM backend on an internal server. Every employee points their desktop app at the same URL.
                  Recommended for teams of 5+ and for enterprise environments with SSO.
                </p>
              </div>

              <div class="bg-[color:var(--color-paper)] p-6">
                <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-ink-faint)] mb-3">
                  Option B &nbsp;·&nbsp; Local machine
                </p>
                <h4 class="font-display text-xl leading-tight mb-3">Solo setup.</h4>
                <p class="text-sm text-[color:var(--color-ink-soft)] font-light leading-relaxed">
                  Install the backend on your own machine. The desktop app connects to
                  <code class="font-mono text-xs bg-[color:var(--color-paper-aged)] border border-[color:var(--color-line)] px-1.5 py-0.5 rounded mx-0.5">http://localhost:3100</code>
                  by default. Good for individual contributors and evaluation.
                </p>
              </div>
            </div>

            <!-- Request access CTA -->
            <div class="flex flex-col md:flex-row items-start md:items-center gap-4 mb-8">
              <a
                href="https://studio.alphaluppi.fr/#contact"
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-3 px-7 py-4 bg-[color:var(--color-ink)] text-[color:var(--color-paper)] text-sm font-medium tracking-wide hover:bg-[color:var(--color-ink-soft)] transition-colors"
              >
                Request backend access
                <span class="text-xs opacity-60">↗</span>
              </a>
              <p class="text-xs text-[color:var(--color-ink-mute)] font-light max-w-md leading-relaxed">
                Tell us about your use case and we'll share the backend package with setup instructions.
              </p>
            </div>

            <!-- Gatekeeper workaround -->
            <div class="text-xs text-[color:var(--color-ink-mute)] font-light leading-relaxed border-l-2 border-[color:var(--color-line-strong)] pl-4">
              <p class="mb-2"><strong class="text-[color:var(--color-ink-soft)]">First launch — Gatekeeper:</strong> the DMG is ad-hoc signed but not notarized by Apple. On macOS Sonoma and later, you must remove the quarantine flag once with:</p>
              <pre class="font-mono text-[11px] bg-[color:var(--color-paper)] border border-[color:var(--color-line)] px-3 py-2 rounded mb-2 overflow-x-auto text-[color:var(--color-ink)]"><code>xattr -dr com.apple.quarantine /Applications/MnM.app</code></pre>
              <p>A signed + notarized build is planned for a future release.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      // After a .dmg download starts, smooth-scroll to the setup guide
      // so users see the post-download instructions without having to
      // hunt for them manually.
      const downloadLinks = document.querySelectorAll<HTMLAnchorElement>(
        '#download a[href$=".dmg"]'
      );
      for (const link of downloadLinks) {
        link.addEventListener('click', () => {
          // Let the download actually start before scrolling
          window.setTimeout(() => {
            const guide = document.getElementById('mnm-setup-guide');
            if (!guide) return;
            const nav = document.getElementById('site-nav');
            const navH = nav ? nav.getBoundingClientRect().height : 0;
            const top =
              guide.getBoundingClientRect().top + window.scrollY - navH - 32;
            window.scrollTo({ top, behavior: 'smooth' });
          }, 150);
        });
      }
    </script>

    <!-- Secondary CTA -->
    <div class="mt-16 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 pt-12 border-t border-[color:var(--color-line)]" data-fade>
      <p class="text-sm text-[color:var(--color-ink-mute)] max-w-md font-light">
        Need it today? The web version is fully functional and production-ready.
        Same features, accessible from any browser.
      </p>
      <a
        href="https://mnm.tomandrieu.com"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-3 px-7 py-4 border border-[color:var(--color-ink)] text-[color:var(--color-ink)] text-sm font-medium tracking-wide hover:bg-[color:var(--color-ink)] hover:text-[color:var(--color-paper)] transition-colors whitespace-nowrap"
      >
        Try the web version
        <span class="text-xs opacity-60">↗</span>
      </a>
    </div>
  </div>
</section>
