---
const year = new Date().getFullYear();
---

<footer class="relative px-6 lg:px-12 py-20 lg:py-28 bg-[color:var(--color-paper-aged)]">
  <div class="mx-auto max-w-7xl">
    <!-- Top: Large wordmark + mono signature -->
    <div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-12 mb-20" data-fade>
      <div>
        <h2 class="font-display text-6xl md:text-7xl lg:text-8xl leading-none tracking-tight text-[color:var(--color-ink)]">
          M<span class="italic text-[color:var(--color-ink-soft)]">n</span>M
        </h2>
        <p class="mt-4 font-mono text-[11px] uppercase tracking-[0.2em] text-[color:var(--color-ink-mute)]">
          Make No Mistake
        </p>
      </div>

      <div class="font-mono text-[11px] uppercase tracking-[0.15em] text-[color:var(--color-ink-mute)] md:text-right">
        <p>Made by</p>
        <p class="text-[color:var(--color-ink-soft)] mt-1">Studio Manifeste</p>
        <p class="mt-4 text-[color:var(--color-ink-faint)]">© {year}</p>
      </div>
    </div>

    <!-- Separator -->
    <div class="rule-hand mb-16"></div>

    <!-- Bottom grid: links, meta -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-ink-faint)] mb-4">
          Product
        </p>
        <ul class="space-y-3">
          <li><a href="#features" class="text-sm text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-ink)] transition-colors">Features</a></li>
          <li><a href="#download" class="text-sm text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-ink)] transition-colors">Download</a></li>
          <li><a href="https://mnm.tomandrieu.com" target="_blank" rel="noopener" class="text-sm text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-ink)] transition-colors">Web version</a></li>
          <li><a href="/changelog" class="text-sm text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-ink)] transition-colors">Changelog</a></li>
        </ul>
      </div>

      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-ink-faint)] mb-4">
          Resources
        </p>
        <ul class="space-y-3">
          <li><a href="https://github.com/AlphaLuppi/mnm" target="_blank" rel="noopener" class="text-sm text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-ink)] transition-colors">GitHub</a></li>
          <li><a href="#" class="text-sm text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-ink)] transition-colors">Documentation</a></li>
          <li><a href="#" class="text-sm text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-ink)] transition-colors">Changelog</a></li>
        </ul>
      </div>

      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-ink-faint)] mb-4">
          Company
        </p>
        <ul class="space-y-3">
          <li><a href="https://alphaluppi.fr" target="_blank" rel="noopener" class="text-sm text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-ink)] transition-colors">Studio Manifeste</a></li>
          <li><a href="#" class="text-sm text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-ink)] transition-colors">Contact</a></li>
        </ul>
      </div>

      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-ink-faint)] mb-4">
          Status
        </p>
        <div class="flex items-center gap-2 text-sm text-[color:var(--color-ink-soft)]">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[color:var(--color-accent-soft)] opacity-50"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-[color:var(--color-accent)]"></span>
          </span>
          <span>v0.1 Preview</span>
        </div>
        <p class="mt-3 text-xs text-[color:var(--color-ink-faint)] font-light max-w-[12rem]">
          Native desktop builds coming soon.
        </p>
      </div>
    </div>
  </div>
</footer>
