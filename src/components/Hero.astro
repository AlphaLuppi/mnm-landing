---
// Hero — asymmetric grid, oversized serif, generous whitespace.
---

<section class="relative min-h-[92dvh] flex items-center px-6 lg:px-12 pt-32 pb-24 overflow-hidden">
  <div class="mx-auto max-w-7xl w-full grid grid-cols-12 gap-6 lg:gap-12 items-center">
    <!-- Left: oversized serif tagline (full width — no side column) -->
    <div class="col-span-12">
      <div class="flex items-center gap-3 mb-10" data-fade>
        <span class="h-px w-12 bg-[color:var(--color-line-strong)]"></span>
        <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-[color:var(--color-ink-mute)]">
          v0.1 — macOS preview
        </span>
      </div>

      <h1 class="font-display text-5xl sm:text-6xl md:text-7xl lg:text-8xl xl:text-9xl leading-[0.95] tracking-tight text-[color:var(--color-ink)]">
        <span class="inline-block" data-fade="blur" style="--fade-delay: 120ms;">Make</span><br/>
        <span class="inline-block italic text-[color:var(--color-ink-soft)]" data-fade="blur" style="font-variation-settings: 'SOFT' 100, 'WONK' 1; --fade-delay: 320ms;">no</span><br/>
        <span class="inline-block" data-fade="blur" style="--fade-delay: 520ms;">Mistake.</span>
      </h1>

      <p class="mt-12 max-w-xl text-lg md:text-xl leading-relaxed text-[color:var(--color-ink-soft)] font-light" data-fade style="--fade-delay: 780ms;">
        The supervision cockpit for AI agents. Orchestrate, trace, and govern
        your agent workflows — built for teams who can't afford to be wrong.
      </p>

      <div class="mt-14 flex flex-col sm:flex-row items-start sm:items-center gap-6" data-fade style="--fade-delay: 980ms;">
        <a
          href="#download"
          class="group inline-flex items-center gap-3 px-7 py-4 bg-[color:var(--color-ink)] text-[color:var(--color-paper)] text-sm font-medium tracking-wide hover:bg-[color:var(--color-ink-soft)] transition-colors"
        >
          Download for macOS
          <span class="text-xs opacity-60 group-hover:translate-x-1 transition-transform">→</span>
        </a>
        <a
          href="https://mnm.tomandrieu.com"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 text-sm text-[color:var(--color-ink-mute)] hover:text-[color:var(--color-ink)] transition-colors"
        >
          Try the web version
          <span class="text-xs opacity-60">↗</span>
        </a>
      </div>
    </div>

  </div>

  <!-- Bottom scroll hint — fades out as soon as the user starts scrolling.
       Outer div handles the fade transition; inner div handles the bob
       animation. Separating them avoids the CSS animation fighting the
       inline opacity toggle. -->
  <div
    id="hero-scroll-hint"
    class="absolute bottom-10 left-1/2 -translate-x-1/2 transition-opacity duration-500 ease-out"
    data-fade
    style="--fade-delay: 1400ms;"
  >
    <div class="flex flex-col items-center gap-2 animate-scroll-bob">
      <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-ink-mute)]">Scroll</span>
      <span class="h-8 w-px bg-[color:var(--color-ink-mute)]"></span>
    </div>
  </div>
</section>

<script>
  // Fade the scroll hint out once the user starts scrolling.
  const hint = document.getElementById('hero-scroll-hint');
  if (hint) {
    const onScroll = () => {
      if (window.scrollY > 60) {
        hint.style.opacity = '0';
        hint.style.pointerEvents = 'none';
      } else {
        hint.style.opacity = '';
        hint.style.pointerEvents = '';
      }
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
