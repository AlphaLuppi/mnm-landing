      </a>
    </div>
  </div>
</nav>

<script>
  // Nav becomes denser on scroll ‚ÄĒ subtle border appears
  const nav = document.getElementById('site-nav');
  if (nav) {
    const onScroll = () => {
      if (window.scrollY > 20) {
        nav.classList.add('border-[color:var(--color-line)]/60');
      } else {
        nav.classList.remove('border-[color:var(--color-line)]/60');
      }
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
